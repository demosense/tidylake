# -----------------------------------------------------------------------------
# 📁 PYTHON: compiled files, environments, caches
# -----------------------------------------------------------------------------
# Python-generated files
__pycache__/
*.py[cod]
*.so

# Build artifacts
build/
dist/
wheels/
*.egg-info
.ruff_cache
.env

# Virtual environments
.venv


# -----------------------------------------------------------------------------
# 📁 CDK & AWS: context, output, credentials
# -----------------------------------------------------------------------------
cdk.context.json
cdk.out/

# AWS credentials (never commit real ones!)
credentials.json
*.pem

# CloudFormation-related envs
.env.cloudformation

# -----------------------------------------------------------------------------
# 📁 NODE & JAVASCRIPT: dependencies, builds, logs
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn-error.log

# Optional build artifacts (adjust for your CDK + JS tooling)
core/build/
core/**/*.c
core/**/*.so

# -----------------------------------------------------------------------------
# 🧪 TESTING & COVERAGE
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.hypothesis/

# -----------------------------------------------------------------------------
# 🧑‍💻 IDEs & EDITORS
# -----------------------------------------------------------------------------
.idea/
.vscode/

# -----------------------------------------------------------------------------
# 📓 JUPYTER NOTEBOOKS
# -----------------------------------------------------------------------------
**/*.ipynb
**/.ipynb_checkpoints/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# 🧾 ENVIRONMENT FILES
# -----------------------------------------------------------------------------
.env*
!.env.example

# -----------------------------------------------------------------------------
# 🗃️ SYSTEM & OS FILES
# -----------------------------------------------------------------------------
*.DS_Store*

# -----------------------------------------------------------------------------
# 📦 LOCAL / PROJECT-SPECIFIC
# -----------------------------------------------------------------------------
local_data/
.amazonq
